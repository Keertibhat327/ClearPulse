# ═══════════════════════════════════════════════════════════════
# ClearPulse Backend - Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your production values
# NEVER commit the actual .env file to git
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ─────────────────────────────────────────────────────────────
# AI SERVICES
# ─────────────────────────────────────────────────────────────
# Google Gemini AI - Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_production_gemini_api_key_here

# Groq AI (Fallback) - Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────
# DATABASE & STORAGE (InsForge)
# ─────────────────────────────────────────────────────────────
# InsForge - Get from: https://insforge.app
INSFORGE_BASE_URL=https://your-production-instance.insforge.app
INSFORGE_SERVICE_KEY=your_production_service_key_here

# ─────────────────────────────────────────────────────────────
# VIDEO AI (Tavus)
# ─────────────────────────────────────────────────────────────
# Tavus - Get from: https://tavus.io
TAVUS_API_KEY=your_tavus_production_api_key_here
TAVUS_REPLICA_ID=your_replica_id_here

# ─────────────────────────────────────────────────────────────
# VOICE AI (Sarvam)
# ─────────────────────────────────────────────────────────────
# Sarvam - Get from: https://sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ─────────────────────────────────────────────────────────────
# IPFS STORAGE (Pinata)
# ─────────────────────────────────────────────────────────────
# Pinata - Get from: https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
# Generate strong random keys:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

VAULT_MASTER_KEY=generate_strong_32_character_key_here
SECRET_KEY=generate_strong_secret_for_jwt_here

# ─────────────────────────────────────────────────────────────
# CORS - IMPORTANT: Update with your production frontend URL
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─────────────────────────────────────────────────────────────
# MONITORING (Optional)
# ─────────────────────────────────────────────────────────────
# Sentry - Get from: https://sentry.io
SENTRY_DSN=your_sentry_dsn_here

# ─────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────
# 1. Never commit this file with real values
# 2. Use platform secrets (Railway/Vercel) in production
# 3. Rotate keys regularly
# 4. Use different keys for staging and production
# ═══════════════════════════════════════════════════════════════
