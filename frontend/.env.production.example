# ═══════════════════════════════════════════════════════════════
# ClearPulse Frontend - Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.production and fill in your values
# These are PUBLIC variables (exposed to browser)
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# BACKEND API URL - IMPORTANT: Update with your deployed backend
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ─────────────────────────────────────────────────────────────
# BLOCKCHAIN (Optional - if using smart contracts)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress
NEXT_PUBLIC_RESEARCH_TOKEN_ADDRESS=0xYourTokenAddress
NEXT_PUBLIC_STUDY_REGISTRY_ADDRESS=0xYourRegistryAddress

# ─────────────────────────────────────────────────────────────
# ANALYTICS (Optional)
# ─────────────────────────────────────────────────────────────
# Google Analytics - Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# FEATURE FLAGS (Optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TRIAGE=true
NEXT_PUBLIC_ENABLE_RESEARCH=true
NEXT_PUBLIC_ENABLE_VIDEO_CONSULT=true

# ─────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────
# 1. All NEXT_PUBLIC_* variables are exposed to the browser
# 2. Never put API keys or secrets here
# 3. Backend URL must use HTTPS in production
# ═══════════════════════════════════════════════════════════════
